# KDF/MM2 RPC endpoint (server-side only)
KDF_RPC_URL=http://127.0.0.1:7783

# Optional userpass field included in RPC envelope if required by your setup
KDF_RPC_USERPASS=change-me

# Optional request timeout in milliseconds
KDF_RPC_TIMEOUT_MS=15000

# KCB storage root (default: ~/.kcb)
KCB_CONFIG_DIR=

# Source for external coins config cache
KCB_COINS_CONFIG_URL=https://raw.githubusercontent.com/GLEECBTC/coins/refs/heads/master/utils/coins_config.json
# Base URL for coin icons (reserved for future icon cache sync)
KCB_ICONS_BASE_URL=https://raw.githubusercontent.com/GLEECBTC/coins/refs/heads/master/icons

# HTTP timeout in milliseconds for KCB fetches
KCB_HTTP_TIMEOUT_MS=15000

# KCB internal log verbosity
KCB_LOG_LEVEL=info

# Retention window for completed command history in seconds
KCB_COMMAND_RETENTION_SECONDS=30

# Restart API guard token (required for /api/admin/restart)
MM2_RESTART_TOKEN=change-this-admin-token

# Safe restart mode: disabled | systemctl | script
MM2_RESTART_MODE=disabled

# Required in systemctl mode, example: mm2.service
MM2_SYSTEMD_SERVICE=

# Required in script mode, absolute path only, example: /opt/mm2/restart-mm2.sh
MM2_RESTART_SCRIPT=

# Browser-visible polling interval (milliseconds) for internal API refresh
NEXT_PUBLIC_POLL_MS=5000

# Debug popup threshold (critical|error|warning|info|debug|trace)
DEBUG_MESSAGE_LEVEL=warning

# File logging threshold (critical|error|warning|info|debug|trace)
DEBUG_LOG_LEVEL=debug

# Popup auto-close timeout in seconds (0 disables auto-close)
DEBUG_MESSAGE_TIMEOUT=8

# Absolute or relative path for debug log file output
LOG_FILE=./logs/komodo-marketmaker-gui.log
